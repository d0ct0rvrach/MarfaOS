/*
 * kernel.c - Главный файл АккордОС
 */

// Пока мы не сделали систему сборки из 10 файлов, 
// будем подключать их так (это "ленивый" путь, но для начала сойдет)
#include "drivers/video.h"
#include "drivers/keyboard.h"

void wait(int ticks) {
    for (volatile int i = 0; i < ticks * 4000000; i++);
}

// РЕАЛЬНАЯ ПРОВЕРКА ПРОЦЕССОРА
void check_cpu() {
    unsigned int ebx, ecx, edx;
    char vendor[13];
    
    // Инструкция CPUID возвращает имя производителя в EBX, EDX, ECX
    asm volatile("cpuid" : "=b"(ebx), "=c"(ecx), "=d"(edx) : "a"(0));

    *((int*)(vendor)) = ebx;
    *((int*)(vendor + 4)) = edx;
    *((int*)(vendor + 8)) = ecx;
    vendor[12] = '\0';

    kprint("CPU Vendor ID: ", 3, 0, 0x0F);
    kprint(vendor, 3, 15, 0x0E); // Выведет что-то типа GenuineIntel
}

void kmain(void) {
    clear_screen();

    // 1. Красивый заголовок
    kprint("--- AKKORD OS SYSTEM DIAGNOSTIC ---", 0, 0, 0x0B);
    wait(2); // Ждем подольше

    // 2. Видеопамять
    kprint("VGA Buffer 0xB8000.......... [ OK ]", 2, 0, 0x0A);
    wait(1);

    // 3. РЕАЛЬНАЯ ПРОВЕРКА ПРОЦЕССОРА
    check_cpu(); 
    // Внутри check_cpu уже есть kprint на 3-ю строку
    wait(1);

    // 4. Клавиатура
    kprint("PS/2 Controller (0x64)......", 4, 0, 0x0F);
    unsigned char status = inb(0x64);
    if (status != 0xFF) {
        kprint("[ READY ]", 4, 30, 0x0A);
    } else {
        kprint("[ ERROR ]", 4, 30, 0x0C);
    }
    wait(1);

    // --- ВОТ ТУТ ПАУЗА ---
    kprint("PRESS ANY KEY TO START SHELL...", 6, 0, 0x0E);
    
    // Ждем, пока ты что-то нажмешь (опрашиваем порт клавиатуры)
    unsigned char key = 0;
    while(key == 0) {
        if(inb(0x64) & 1) { // Если в буфере что-то есть
            key = inb(0x60);
        }
    }

    clear_screen();
    kprint("AKKORD OS IS READY.", 0, 0, 0x0F);
    kprint("vlad@akkord_os:~$ ", 2, 0, 0x0A);

    int cursor_pos = 2 * 80 + 18;
    unsigned char last_scancode = 0;

    while(1) {
        unsigned char scancode = inb(0x60);
        if (scancode != last_scancode && scancode < 0x80) {
            char c = scan_to_char(scancode);
            if (c != 0) {
                if (c == '\n') {
                    cursor_pos = ((cursor_pos / 80) + 1) * 80;
                    kprint("vlad@akkord_os:~$ ", cursor_pos / 80, 0, 0x0A);
                    cursor_pos += 18;
                }
                else if (c == '\b') {
                    if (cursor_pos > ((cursor_pos / 80) * 80 + 18)) {
                        cursor_pos--;
                        put_char(' ', cursor_pos, 0x0F);
                    }
                }
                else {
                    put_char(c, cursor_pos++, 0x0F);
                }
            }
            last_scancode = scancode;
        }
        for(volatile int j=0; j<1000; j++);
    }
}